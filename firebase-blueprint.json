{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Administrator of the system",
      "type": "object",
      "properties": {
        "role": {
          "type": "string"
        }
      },
      "required": ["role"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Recreation worker details, workdays, and availabilities",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "artisticName": { "type": "string" },
        "email": { "type": "string" },
        "userId": { "type": "string" },
        "level": { "type": "string" },
        "dailyRate": { "type": "number" },
        "partyRate": { "type": "number" },
        "extraHourRate": { "type": "number" },
        "workDays": {
          "type": "array"
        },
        "availabilities": {
          "type": "array"
        }
      },
      "required": ["name", "email"]
    },
    "DeadlineSetting": {
      "title": "Deadline Setting",
      "description": "Map of year-month keys to deadline ISO strings",
      "type": "object",
      "properties": {}
    },
    "AccessLog": {
      "title": "Access Log",
      "description": "Log of user login and access events",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["email", "name", "timestamp"]
    }
  },
  "firestore": {
    "/usuarios_admin/{email}": {
      "schema": "Admin",
      "description": "Users with admin access"
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Employee profiles, workdays, and availabilities"
    },
    "/settings/deadlines": {
      "schema": "DeadlineSetting",
      "description": "Deadlines for submitting work availabilities"
    },
    "/access_logs/{logId}": {
      "schema": "AccessLog",
      "description": "Logs of accesses and logins"
    }
  }
}
